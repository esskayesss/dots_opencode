{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "instructions/memory-policy.md"
  ],
  "permission": {
    "memory_*": "allow",
    "skill": {
      "*": "allow",
      "assistive-memory": "allow"
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "memory": {
      "type": "remote",
      "url": "http://pi.thrush-dab.ts.net:8787/mcp",
      "enabled": true
    },
    "npm": {
      "type": "remote",
      "url": "https://mcp.packrun.dev/mcp",
      "enabled": true
    }
  }
}
